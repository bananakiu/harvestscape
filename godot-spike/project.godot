; HarvestScape — Godot migration spike
; Minimal Godot 4.x project. Mirrors the shipped build's rendering model:
;   internal 320x208 buffer, nearest-neighbour, integer-upscaled ~4x.
config_version=5

[application]
config/name="HarvestScape — Godot Migration Spike"
run/main_scene="res://main.tscn"

[display]
window/size/viewport_width=320
window/size/viewport_height=208
window/size/window_width_override=1280
window/size/window_height_override=832
window/stretch/mode="viewport"

[rendering]
textures/canvas_textures/default_texture_filter=0
